+    # ── Core: acquire_page (Page Lease) ─────────────────────
+
+    @contextlib.asynccontextmanager
+    async def acquire_page(
+        self, *, timeout: float = 30.0
+    ):
+        """Lease the page to a single query (async context manager).
+
+        Behaviour:
+          - Refuses with :class:`PageBusyError` if the page is already
+            leased, the runtime is in recovery, or a pending eviction
+            is in flight.
+          - Waits up to ``timeout`` seconds for the lease to become
+            available before giving up.
+          - On exit (success or exception), releases the lease and
+            bumps ``_metrics.page_lease_released``.
+
+        Use as::
+
+            async with engine.acquire_page() as page:
+                await adapter.execute(page, prompt, options)
+        """
+        # Guard 1: recovery in progress — refuse all new leases
+        if self._recovery_in_progress:
+            self._metrics.page_busy_rejections += 1
+            raise PageBusyError(
+                self._platform, "runtime is under recovery"
+            )
+
+        # Guard 2: page being torn down — refuse all new leases
+        if self._pending_evict:
+            self._metrics.page_busy_rejections += 1
+            raise PageBusyError(
+                self._platform, "page is being evicted"
+            )
+
+        # Guard 3: state must be READY (mirrors get_page())
+        if self.state != RuntimeState.READY:
+            self._metrics.page_busy_rejections += 1
+            raise RuntimeNotReadyError(self.state)
+
+        # Acquire the lease (with timeout)
+        try:
+            await asyncio.wait_for(self._lease_lock.acquire(), timeout=timeout)
+        except asyncio.TimeoutError as exc:
+            self._metrics.page_busy_rejections += 1
+            raise PageBusyError(
+                self._platform,
+                f"lease acquisition timed out after {timeout:.1f}s",
+            ) from exc
+
+        # We hold the lease — bump ref count + metrics
+        self._query_ref_count += 1
+        self._metrics.page_lease_acquired += 1
+        self._page_state = PageBusyState.LEASED
+        self._page_last_used = time.time()
+        try:
+            yield self._page
+        finally:
+            self._query_ref_count = max(0, self._query_ref_count - 1)
+            self._metrics.page_lease_released += 1
+            if self._query_ref_count == 0 and not self._recovery_in_progress:
+                self._page_state = PageBusyState.IDLE
+            if self._lease_lock.locked():
+                self._lease_lock.release()
+
+    # ── Core: metrics ──────────────────────────────────────
+
+    def metrics(self) -> RuntimeMetrics:
+        """Return this engine's mutable metrics counters."""
+        return self._metrics
+
+    @property
+    def page_state(self) -> PageBusyState:
+        """Current sub-state of the page lease."""
+        return self._page_state
+
+    @property
+    def query_ref_count(self) -> int:
+        """Number of queries currently holding the page lease."""
+        return self._query_ref_count
+
+    @property
+    def recovery_in_progress(self) -> bool:
+        """True while a recovery round is running."""
+        return self._recovery_in_progress
+
