{
  "$schema": "https://raw.githubusercontent.com/nicholasq/tauri-conf-schema/main/tauri.conf.schema.json",
  "productName": "OmniCouncil",
  "version": "0.1.0",
  "identifier": "com.omnicouncil.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OmniCouncil",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": []
    }
  }
}
