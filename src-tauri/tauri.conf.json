{
  "$schema": "https://raw.githubusercontent.com/nicholasq/tauri-conf-schema/main/tauri.conf.schema.json",
  "productName": "OmniCouncil",
  "version": "0.1.0",
  "identifier": "com.omnicouncil.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OmniCouncil",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws://localhost:8765 http://localhost:8765; img-src 'self' data: https:; frame-src 'none'; object-src 'none'"
    }
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": []
    }
  }
}
